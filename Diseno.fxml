<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>

<VBox alignment="CENTER"
      spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controlador">

    <Label text="Conversor de Monedas"/>

    <Label text="Monto en Pesos Dominicanos"/>

    <TextField fx:id="txMonto"
               onKeyPressed="#presioneEnter"/>

    <Label text="Moneda destino"/>

    <ComboBox fx:id="cmbModena"/>

    <HBox alignment="CENTER" spacing="10">

        <Button text="Convertir"
                onAction="#convertir"
                onMouseEntered="#MauseEntra"
                onMouseExited="#MauseSaali"/>

        <Button text="Limpiar"
                onAction="#limpiar"/>

    </HBox>

    <Label fx:id="lblResultado"/>

    <Label fx:id="lblMnesaje"
           text="Esperando Informacion..."/>

</VBox>